# Williams Entry Radar — environment template
#
# Copy this file to .local-secrets and fill in real values. NEVER commit secrets.
# Prior AV key was leaked in commits 92c8c8d, 0943cd7, f22fdc7 —
# rotate AV_API_KEY at https://www.alphavantage.co/premium/ before running.

# Alpha Vantage (required) — use Premium; free tier hits rate limits.
AV_API_KEY=your_alphavantage_premium_key

# GitHub (required). Fine-grained PAT scoped to contents:write on this repo only.
GH_TOKEN=github_pat_your_fine_grained_token
GH_REPO=EurekaMD-net/Williams-Entry-Radar

# Telegram (required for notify).
TELEGRAM_BOT_TOKEN=1234567890:your_bot_token_from_BotFather
TELEGRAM_CHAT_ID=-1001234567890

# Xpoz Reddit enrichment (optional). 4xx with key set will FAIL LOUD.
XPOZ_API_KEY=
XPOZ_BASE_URL=https://api.xpoz.io

# Timezone — scheduler forces America/Mexico_City via Intl.DateTimeFormat.
# Setting TZ in systemd only controls process-local time in logs.
TZ=America/Mexico_City

# Overrides (optional)
# RADAR_RESULTS_DIR=/tmp/radar-results
# RADAR_DB_PATH=/tmp/radar.db
