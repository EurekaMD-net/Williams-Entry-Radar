{
  "name": "williams-entry-radar",
  "version": "1.0.0",
  "description": "Backtesting engine for Bill Williams AO/AC entry signal detection",
  "type": "module",
  "scripts": {
    "backtest": "npx tsx src/backtest.ts",
    "radar": "npx tsx src/radar.ts",
    "scheduler": "npx tsx src/scheduler.ts",
